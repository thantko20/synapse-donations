{
  "name": "@repo/api",
  "type": "module",
  "exports": {
    "./trpc": "./src/trpc/index.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "create-admin": "tsx src/scripts/create-admin.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:db:reset": "npm run test:db:down && npm run test:db:up && sleep 5 && npm run db:migrate:test",
    "db:migrate:test": "dotenv -e .env.test -- prisma migrate dev --name init",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.5",
    "@hono/trpc-server": "^0.4.0",
    "@hono/zod-validator": "^0.7.4",
    "@prisma/client": "6.16.3",
    "@repo/shared": "workspace:*",
    "@trpc/server": "^11.6.0",
    "bcrypt": "^6.0.0",
    "effect": "^3.18.2",
    "hono": "^4.9.9",
    "superjson": "^2.2.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/dotenv": "^8.2.3",
    "@types/node": "^20.11.17",
    "dotenv": "^16.4.5",
    "dotenv-cli": "^7.4.2",
    "prisma": "^6.16.3",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}